rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    // Public / transient control-plane records are backend-only. Admin SDK bypasses rules.
    match /device_codes/{document=**} {
      allow read, write: if false;
    }

    match /control_plane_rate_limits/{document=**} {
      allow read, write: if false;
    }

    match /control_plane_idempotency/{document=**} {
      allow read, write: if false;
    }

    match /control_plane_audit/{document=**} {
      allow read, write: if false;
    }

    match /billing_events/{document=**} {
      allow read, write: if false;
    }

    match /waitlist/{document=**} {
      allow read, write: if false;
    }

    match /install_codes/{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      // Root user doc should never be created/modified by clients.
      allow read, write: if false;
    }

    match /users/{userId}/agents/{document} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /users/{userId}/events/{document} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /users/{userId}/incidents/{document} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /users/{userId}/incident_cases/{document} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /users/{userId}/team_members/{document} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /users/{userId}/entitlements/{document} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /users/{userId}/seat_usage/{document} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /users/{userId}/subscriptions/{document} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /users/{userId}/agent_seats/{document} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /users/{userId}/referral_credits/{document} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /users/{userId}/credential_shares/{document} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /users/{userId}/agent_sync/{document} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /users/{userId}/api_keys/{document} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /users/{userId}/enrollment_tokens/{document} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /users/{userId}/settings/{document} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /users/{userId}/pilot/{document} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /users/{userId}/{document=**} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
