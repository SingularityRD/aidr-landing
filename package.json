{
  "name": "landing",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "dev": "next dev -p 4567",
    "build": "next build",
    "start": "next start -p 4567",
    "test": "vitest run",
    "test:incident-case": "vitest run src/lib/__tests__/incident-case.test.ts src/lib/control-plane/__tests__/incident-case.test.ts",
    "quality:gate": "pnpm lint && pnpm test && pnpm build",
    "verify:release-candidate": "pnpm test:incident-case && pnpm quality:gate && pnpm smoke:onboarding:ci",
    "smoke:onboarding": "node scripts/smoke-onboarding.mjs",
    "smoke:onboarding:ci": "node scripts/smoke-onboarding-with-server.mjs",
    "lint": "eslint",
    "check-env": "node scripts/check-env.js",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "opennextjs-cloudflare build && wrangler dev",
    "cf:deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.2.5",
    "@polar-sh/sdk": "^0.47.0",
    "@sentry/nextjs": "^10.55.0",
    "firebase": "^12.14.0",
    "firebase-admin": "^13.10.0",
    "geist": "^1.7.0",
    "next": "16.2.6",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "standardwebhooks": "1.0.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.17.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.2",
    "wrangler": "^4.69.0"
  },
  "overrides": {
    "postcss@<8.5.10": ">=8.5.10",
    "fast-uri@<=3.1.0": ">=3.1.1",
    "fast-uri@<=3.1.1": ">=3.1.2",
    "protobufjs@<=7.5.5": ">=7.5.6",
    "@protobufjs/utf8@<=1.1.0": ">=1.1.1",
    "fast-xml-builder@<=1.1.6": ">=1.1.7",
    "fast-xml-builder@=1.1.5": ">=1.1.6",
    "brace-expansion@>=5.0.0 <5.0.6": ">=5.0.6",
    "protobufjs@<=7.5.7": ">=7.5.8",
    "@tootallnate/once@<2.0.1": ">=2.0.1",
    "uuid@<11.1.1": ">=11.1.1",
    "js-cookie@<=3.0.5": ">=3.0.7"
  }
